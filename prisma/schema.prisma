// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          Int         @id @default(autoincrement())
  email       String      @unique
  name        String
  password    String
  telephone   String      @default("")
  role        Role        @default(DRIVER)
  photo       String      @default("")
  gender      Gender      @default(MALE)
  city        String      @default("")
  state       String      @default("")
  refreshToken String?    @default("")
  createdAt   DateTime    @default(now())
  instructor  Instructor?
  driver      Driver?
}

model Instructor {
  id          Int      @id @default(autoincrement())
  priceHour   Decimal
  latitude    Float?
  longitude   Float?
  bio         String
  cnh         String   @default("")
  active      Boolean
  hasVehicle  Boolean  @default(false)
  rating      Float    @default(0)
  rangeKm     Float    @default(0)
  createdAt   DateTime @default(now())
  userId      Int      @unique

  user                 User                 @relation(fields: [userId], references: [id])
  instructorCategories InstructorCategory[]
  instructorVehicles   InstructorVehicle[]
}

model VehicleType {
  id                   Int                  @id @default(autoincrement())
  id_seeder            Int                  @unique
  name                 String               @unique
  description          String
  instructorVehicles   InstructorVehicle[]
}

model InstructorVehicle {
  id            Int         @id @default(autoincrement())
  instructorId  Int
  vehicleTypeId Int
  instructor    Instructor  @relation(fields: [instructorId], references: [id])
  vehicleType   VehicleType @relation(fields: [vehicleTypeId], references: [id])
}

model Driver {
  id               Int     @id @default(autoincrement())
  active           Boolean
  userId           Int     @unique

  user            User            @relation(fields: [userId], references: [id])
}

model LicenseCategory {
  id                   Int                  @id @default(autoincrement())
  id_seeder            Int                  @unique
  acronym              Category             @unique
  description          String
  instructorCategories InstructorCategory[]
}

model InstructorCategory {
  id              Int             @id @default(autoincrement())
  instructorId    Int
  categoryId      Int
  instructor      Instructor      @relation(fields: [instructorId], references: [id])
  licenseCategory LicenseCategory @relation(fields: [categoryId], references: [id])
}

enum Gender {
  MALE
  FEMALE
}

enum Role {
  DRIVER
  INSTRUCTOR
}

enum Category {
  A
  B
  C
  D
  E
}
